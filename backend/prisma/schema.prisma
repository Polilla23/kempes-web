generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

model User {
  id                        String    @id @default(uuid())
  email                     String    @unique
  password                  String
  username                  String?   @unique
  avatar                    String?   @map("avatar_url")
  role                      RoleType? @default(USER)
  isVerified                Boolean   @default(false) @map("is_verified")
  resetPasswordToken        String?   @unique @map("reset_password_token")
  resetPasswordTokenExpires DateTime? @map("reset_password_token_expires")
  club      Club?
  news      News[]
  comments  Comment[]
  newsLikes NewsLike[]

  @@map("users")
}

model Club {
  id                 String   @id @default(uuid())
  name               String   @unique
  logo               String?
  userId             String?  @unique @map("user_id")
  user               User?    @relation(fields: [userId], references: [id], onDelete: Cascade)
  playerOwner        Player[] @relation("OwnerClub")
  playerNow          Player[] @relation("ActualClub")
  isActive           Boolean  @default(true) @map("is_active")
  preferredFormation String?  @default("4-3-3") @map("preferred_formation")

  homeMatches       Match[]            @relation("HomeMatches")
  awayMatches       Match[]            @relation("AwayMatches")
  competitions      Competition[]      @relation("CompetitionTeams")
  seasonTransitions SeasonTransition[]
  clubHistory       ClubHistory[]
  playerSeasonStats PlayerSeasonStats[]
  coefKempes        CoefKempes[]
  matchCovids       MatchCovid[]

  // Transfer and finance relations
  transfersFrom         Transfer[]  @relation("TransferFromClub")
  transfersTo           Transfer[]  @relation("TransferToClub")
  transfersInitiated    Transfer[]  @relation("TransferInitiator")
  financialTransactions FinancialTransaction[]
  seasonBalances        ClubSeasonBalance[]
  playerSeasonHalfClubs PlayerSeasonHalfClub[]

  @@index([userId])
  @@map("clubs")
}

model Player {
  id                String              @id @default(uuid())
  fullName          String              @map("full_name")
  birthdate         DateTime
  actualClubId      String              @default("null") @map("actual_club_id")
  ownerClubId       String              @default("null") @map("owner_club_id")
  actualClub        Club                @relation("ActualClub", fields: [actualClubId], references: [id])
  ownerClub         Club                @relation("OwnerClub", fields: [ownerClubId], references: [id])
  overall           Int?                @default(0)
  salary            Float               @default(100.000)
  sofifaId          String?             @default("null") @map("sofifa_id")
  transfermarktId   String?             @default("null") @map("transfermarkt_id")
  isKempesita       Boolean             @default(false) @map("is_kempesita")
  isActive          Boolean             @default(true) @map("is_active")
  avatar            String?             @map("avatar_url")
  position          PlayerPosition?
  events            Event[]
  playerSeasonStats PlayerSeasonStats[]
  matchCovids   MatchCovid[]

  // Transfer relations
  transfers             Transfer[]
  transferPayments      TransferPlayerPayment[]
  playerSeasonHalfClubs PlayerSeasonHalfClub[]

  @@map("players")
}

model SalaryRate {
  id         String  @id @default(uuid())
  minOverall Int     @map("min_overall") // Media mínima
  maxOverall Int     @map("max_overall") // Media máxima
  salary     Float // Salario correspondiente
  isActive   Boolean @default(true) @map("is_active")

  @@map("salary_rates")
}

model KempesitaConfig {
  id           String   @id @default(uuid())
  maxBirthYear Int      @map("max_birth_year")
  isActive     Boolean  @default(true) @map("is_active")
  createdAt    DateTime @default(now()) @map("created_at")
  updatedAt    DateTime @updatedAt @map("updated_at")

  @@map("kempesita_configs")
}

model Season {
  id                String              @id @default(uuid())
  number            Int                 @unique
  isActive          Boolean             @default(false)
  competitions      Competition[]
  seasonTransitions SeasonTransition[]
  clubHistory       ClubHistory[]
  playerSeasonStats PlayerSeasonStats[]
  coefKempes    CoefKempes[]

  // Season halves relation
  seasonHalves  SeasonHalf[]
  deadlines     SeasonDeadline[]
}

model Competition {
  id                  String           @id @default(uuid())
  name                String // Nombre constuido, ej: "Liga A Mayores - T7", "Copa de Oro - T10"
  system              CompetitionStage // Sitema de juego de ESTA instancia/fase
  seasonId            String
  isActive            Boolean          @default(true)
  competitionTypeId   String
  // Para conectar fases (ej. Copa de Oro es hija de Copa Kempes)
  parentCompetitionId String?          @unique
  parentCompetition   Competition?     @relation("CompetitionPhases", fields: [parentCompetitionId], references: [id])
  childCompetition    Competition?     @relation("CompetitionPhases")
  // El cerebro de la flexibilidad: Aquí guardamos las reglas específicas.
  rules               Json

  season          Season          @relation(fields: [seasonId], references: [id])
  competitionType CompetitionType @relation(fields: [competitionTypeId], references: [id])
  teams           Club[]          @relation("CompetitionTeams")
  matches         Match[]
  plazoScopes     PlazoScope[]

  seasonTransitionsFrom SeasonTransition[]  @relation("FromCompetition")
  seasonTransitionsTo   SeasonTransition[]  @relation("ToCompetition")
  clubHistory           ClubHistory[]
  playerSeasonStats     PlayerSeasonStats[]
  standingsSnapshot     StandingsSnapshot?
}

model CompetitionType {
  id           String              @id @default(uuid())
  category     CompetitionCategory // "SENIOR" o "KEMPESITA"
  hierarchy    Int // 1, 2, 3... para ordenar las ligas (Liga A = 1, Liga B = 2...)
  name         CompetitionName // "Liga A", "Copa Kempes"
  format       CompetitionFormat // Es una LIGA o una COPA
  trophyImage  String?             @map("trophy_image_url")
  competitions Competition[]

  // Prize configuration relation
  prizes        CompetitionPrize[]

  @@unique([category, name])
}

model Match {
  id            String           @id @default(uuid())
  matchdayOrder Int // Fecha 1, 2... o número de orden
  status        MatchStatus      @default(PENDIENTE)
  stage         CompetitionStage // "ROUND_ROBIN" o "KNOCKOUT"

  // Ronda explícita para eliminatorias. NULL para ligas/grupos.
  knockoutRound KnockoutRound? @map("knockout_round")

  homeClubId      String?
  awayClubId      String?
  homePlaceholder String?
  awayPlaceholder String?
  homeClubGoals   Int     @default(0)
  awayClubGoals   Int     @default(0)
  homeOwnGoals    Int     @default(0) @map("home_own_goals")
  awayOwnGoals    Int     @default(0) @map("away_own_goals")
  competitionId   String
  events          Event[]

  homeSourceMatchId  String? @map("home_source_match_id")
  awaySourceMatchId  String? @map("away_source_match_id")
  homeSourcePosition String? @map("home_source_position") // "WINNER" or "LOSER"
  awaySourcePosition String? @map("away_source_position") // "WINNER" or "LOSER"

  competition Competition @relation(fields: [competitionId], references: [id], onDelete: Cascade)
  homeClub    Club?       @relation("HomeMatches", fields: [homeClubId], references: [id], onDelete: SetNull)
  awayClub    Club?       @relation("AwayMatches", fields: [awayClubId], references: [id], onDelete: SetNull)

  homeSourceMatch Match?  @relation("HomeSourceMatch", fields: [homeSourceMatchId], references: [id], onDelete: SetNull)
  homeNextMatches Match[] @relation("HomeSourceMatch")

  awaySourceMatch  Match?  @relation("AwaySourceMatch", fields: [awaySourceMatchId], references: [id], onDelete: SetNull)
  dependentMatches Match[] @relation("AwaySourceMatch")

  covidPlayers MatchCovid[]

  resultRecordedAt DateTime? @map("result_recorded_at")

  plazoId  String? @map("plazo_id")
  plazo    Plazo?  @relation(fields: [plazoId], references: [id], onDelete: SetNull)

  @@index([competitionId])
  @@index([homeSourceMatchId])
  @@index([awaySourceMatchId])
  @@index([knockoutRound])
  @@index([plazoId])
}

model MatchCovid {
  id       String @id @default(uuid())
  matchId  String
  playerId String
  clubId   String // Equipo del jugador en este partido (home o away)

  match  Match  @relation(fields: [matchId], references: [id], onDelete: Cascade)
  player Player @relation(fields: [playerId], references: [id], onDelete: Cascade)
  club   Club   @relation(fields: [clubId], references: [id], onDelete: Cascade)

  @@unique([matchId, playerId])
  @@index([matchId])
  @@index([playerId])
  @@map("match_covids")
}

model StandingsSnapshot {
  id            String   @id @default(uuid())
  competitionId String   @unique @map("competition_id")
  data          Json
  updatedAt     DateTime @updatedAt @map("updated_at")

  competition   Competition @relation(fields: [competitionId], references: [id], onDelete: Cascade)

  @@index([competitionId])
  @@map("standings_snapshots")
}

model EventType {
  id          String        @id @default(uuid())
  name        EventTypeName @unique // Enum: GOAL, YELLOW_CARD, RED_CARD, INJURY, MVP
  displayName String        @map("display_name") // Nombre para mostrar: "Gol", "Tarjeta Amarilla", etc.
  icon        String?       @default("⚽") // Emoji o clase de icono
  isActive    Boolean       @default(true) @map("is_active")
  events      Event[]

  @@map("event_types")
}

model Event {
  id       String @id @default(uuid())
  typeId   String
  playerId String
  matchId  String

  player Player    @relation(fields: [playerId], references: [id], onDelete: Cascade)
  match  Match     @relation(fields: [matchId], references: [id], onDelete: Cascade)
  type   EventType @relation(fields: [typeId], references: [id], onDelete: Cascade)

  @@index([playerId])
  @@index([matchId])
}

model StorageFile {
  id           String     @id @default(uuid())
  fileName     String     @map("file_name")
  originalName String     @map("original_name")
  fileSize     Int        @map("file_size")
  mimeType     String     @map("mime_type")
  bucket       String
  path         String
  publicUrl    String     @map("public_url")
  entityType   EntityType @map("entity_type")
  entityId     String?    @map("entity_id")
  uploadedBy   String?    @map("uploaded_by")
  createdAt    DateTime   @default(now()) @map("created_at")
  updatedAt    DateTime   @updatedAt @map("updated_at")
  isActive     Boolean    @default(true) @map("is_active")

  @@index([entityType, entityId])
  @@index([bucket])
  @@map("storage_files")
}

model News {
  id          String   @id @default(uuid())
  title       String
  content     String   @db.Text
  authorId    String   @map("author_id")
  author      User     @relation(fields: [authorId], references: [id], onDelete: Cascade)
  images      String[]
  tags        String[]
  isPublished Boolean  @default(true) @map("is_published")
  publishedAt DateTime @default(now()) @map("published_at")
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")
  comments    Comment[]
  likes       NewsLike[]

  @@index([authorId])
  @@map("news")
}

model NewsLike {
  id        String   @id @default(uuid())
  userId    String   @map("user_id")
  newsId    String   @map("news_id")
  createdAt DateTime @default(now()) @map("created_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
  news News @relation(fields: [newsId], references: [id], onDelete: Cascade)

  @@unique([userId, newsId])
  @@index([newsId])
  @@index([userId])
  @@map("news_likes")
}

model Comment {
  id        String   @id @default(uuid())
  content   String   @db.Text
  authorId  String   @map("author_id")
  newsId    String   @map("news_id")
  author    User     @relation(fields: [authorId], references: [id], onDelete: Cascade)
  news      News     @relation(fields: [newsId], references: [id], onDelete: Cascade)
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@index([newsId])
  @@index([authorId])
  @@map("comments")
}

// ENUMS AND TYPES

enum PlayerPosition {
  GK   // Goalkeeper
  CB   // Centre Back
  LB   // Left Back
  RB   // Right Back
  LWB  // Left Wing Back
  RWB  // Right Wing Back
  CDM  // Central Defensive Midfielder
  CM   // Central Midfielder
  CAM  // Central Attacking Midfielder
  LM   // Left Midfielder
  RM   // Right Midfielder
  LW   // Left Winger
  RW   // Right Winger
  CF   // Centre Forward
  ST   // Striker
}

enum RoleType {
  ADMIN
  USER
}

enum MatchStatus {
  PENDIENTE
  FINALIZADO
  CANCELADO
}

enum CompetitionFormat {
  LEAGUE
  CUP
}

enum CompetitionStage {
  ROUND_ROBIN // Todos contra todos (Ligas, Fase de Grupos)
  KNOCKOUT // Eliminación directa
}

enum KnockoutRound {
  // Copa - Fases estándar
  ROUND_OF_64
  ROUND_OF_32
  ROUND_OF_16
  QUARTERFINAL
  SEMIFINAL
  FINAL
  THIRD_PLACE
  // Liga - Playoffs para definir campeón
  LIGUILLA // Partidos de liguilla (mini liga entre X primeros)
  TRIANGULAR_SEMI // Semi del triangular: 3° vs 2°
  TRIANGULAR_FINAL // Final del triangular: Ganador vs 1°
  // Liga - Playout (pelea por no ir a promoción)
  PLAYOUT // Partido de playout (ej: 5to vs 6to)
  // Liga - Promoción (entre divisiones)
  PROMOTION // Partido de promoción inter-división
  // Liga - Reducido (última división, para ir a promoción)
  REDUCIDO_QUARTER // Cuartos de reducido: 5° vs 6°
  REDUCIDO_SEMI // Semi de reducido: Ganador cuartos vs 4°
  REDUCIDO_FINAL // Final de reducido: Ganador semi vs 3°
}

enum CompetitionCategory {
  SENIOR // For "Mayores" competitions
  KEMPESITA // For "Kempesitas" competitions
  MIXED // For mixed competitions like Supercopa (both Mayores and Kempesitas)
}

enum CompetitionName {
  LEAGUE_A
  LEAGUE_B
  LEAGUE_C
  LEAGUE_D
  LEAGUE_E
  KEMPES_CUP
  GOLD_CUP
  SILVER_CUP
  CINDOR_CUP
  SUPER_CUP
  PROMOTIONS
}

enum EventTypeName {
  GOAL // Gol ⚽
  YELLOW_CARD // Tarjeta Amarilla 🟨
  RED_CARD // Tarjeta Roja 🟥
  INJURY // Lesión 🤕
  MVP // MVP 🌟
}

enum EntityType {
  CLUB
  PLAYER
  TROPHY
  NEWS
  GENERAL
  USER
}

enum MovementType {
  CHAMPION
  DIRECT_PROMOTION
  PLAYOFF_PROMOTION
  REDUCIDO_PROMOTION
  DIRECT_RELEGATION
  PLAYOFF_RELEGATION
  STAYED
}

enum CupPhase {
  GROUPS
  ROUND_OF_16
  QUARTERFINALS
  SEMIFINALS
  FINAL
  CHAMPION
}

// ============================================
// TRANSFER AND FINANCE ENUMS
// ============================================

enum TransferType {
  PURCHASE          // Compra a otro club
  SALE              // Venta a otro club
  LOAN_IN           // Préstamo recibido
  LOAN_OUT          // Préstamo cedido
  AUCTION           // Subasta forzada
  FREE_AGENT        // Pase Libre (club FREE)
  INACTIVE_STATUS   // Pase Inactivo (jugador inactivo)
  RETURN_FROM_LOAN  // Retorno de préstamo (automático)
}

enum TransferStatus {
  PENDING           // Pendiente de aprobación
  ACTIVE            // Activo (préstamos vigentes)
  COMPLETED         // Completada
  CANCELLED         // Cancelada
  PARTIALLY_PAID    // Con cuotas pendientes
}

enum InstallmentStatus {
  PENDING           // No vencida
  DUE               // Actualmente vencida
  PAID              // Pagada
  OVERDUE           // Vencida sin pagar
}

enum TransactionType {
  TRANSFER_INCOME       // Ingreso por venta
  TRANSFER_EXPENSE      // Gasto por compra
  LOAN_FEE_INCOME       // Cargo préstamo recibido
  LOAN_FEE_EXPENSE      // Cargo préstamo pagado
  PRIZE_INCOME          // Premio competición
  FINE_EXPENSE          // Multa
  SALARY_EXPENSE        // Salarios
  BONUS_INCOME          // Bono cumplimiento
  AUCTION_INCOME        // Ingreso subasta
  AUCTION_EXPENSE       // Gasto subasta
  PLAYER_SWAP_CREDIT    // Jugador recibido como pago
  PLAYER_SWAP_DEBIT     // Jugador dado como pago
}

enum SeasonHalfType {
  FIRST_HALF        // Primera mitad
  SECOND_HALF       // Segunda mitad
}

enum TransferWindowStatus {
  OPEN
  CLOSED
}

enum DeadlineType {
  TRANSFER_MARKET
  COVID_REDRAW
  MATCH_SCHEDULE
  INSTALLMENT_DUE
  SEASON_CLOSE
  CUSTOM
}

// ============================================
// HISTORICAL AND MOVEMENT TRACKING MODELS
// ============================================

model SeasonTransition {
  id                String       @id @default(uuid())
  seasonId          String
  clubId            String
  fromCompetitionId String
  toCompetitionId   String?
  movementType      MovementType
  reason            String? // "Campeón", "Posición 1", "Reducido", etc.
  finalPosition     Int? // Posición final en la competición anterior

  season          Season       @relation(fields: [seasonId], references: [id], onDelete: Cascade)
  club            Club         @relation(fields: [clubId], references: [id], onDelete: Cascade)
  fromCompetition Competition  @relation("FromCompetition", fields: [fromCompetitionId], references: [id], onDelete: Cascade)
  toCompetition   Competition? @relation("ToCompetition", fields: [toCompetitionId], references: [id], onDelete: Cascade)

  @@unique([seasonId, clubId])
  @@index([clubId])
  @@index([seasonId])
  @@map("season_transitions")
}

model ClubHistory {
  id            String        @id @default(uuid())
  clubId        String
  seasonId      String
  competitionId String
  finalPosition Int
  points        Int
  played        Int
  won           Int
  drawn         Int
  lost          Int
  goalsFor      Int           @map("goals_for")
  goalsAgainst  Int           @map("goals_against")
  movement      MovementType?

  club        Club        @relation(fields: [clubId], references: [id], onDelete: Cascade)
  season      Season      @relation(fields: [seasonId], references: [id], onDelete: Cascade)
  competition Competition @relation(fields: [competitionId], references: [id], onDelete: Cascade)

  @@unique([clubId, seasonId, competitionId])
  @@index([clubId])
  @@index([seasonId])
  @@map("club_history")
}

model PlayerSeasonStats {
  id            String @id @default(uuid())
  playerId      String
  seasonId      String
  competitionId String
  clubId        String @map("club_id")
  appearances   Int    @default(0)
  goals         Int    @default(0)
  assists       Int    @default(0)
  yellowCards   Int    @default(0) @map("yellow_cards")
  redCards      Int    @default(0) @map("red_cards")
  mvps          Int    @default(0)

  player      Player      @relation(fields: [playerId], references: [id], onDelete: Cascade)
  season      Season      @relation(fields: [seasonId], references: [id], onDelete: Cascade)
  competition Competition @relation(fields: [competitionId], references: [id], onDelete: Cascade)
  club        Club        @relation(fields: [clubId], references: [id], onDelete: Cascade)

  @@unique([playerId, seasonId, competitionId, clubId])
  @@index([playerId])
  @@index([seasonId])
  @@index([clubId])
  @@map("player_season_stats")
}

model CoefKempes {
  id            String  @id @default(uuid())
  clubId        String
  seasonId      String
  points        Float
  cupPhase      CupPhase // Fase máxima alcanzada
  cupName       CompetitionName // KEMPES_CUP, GOLD_CUP, SILVER_CUP

  club          Club    @relation(fields: [clubId], references: [id], onDelete: Cascade)
  season        Season  @relation(fields: [seasonId], references: [id], onDelete: Cascade)

  @@unique([clubId, seasonId, cupName])
  @@index([clubId])
  @@index([seasonId])
  @@map("coef_kempes")
}

// ============================================
// SEASON HALF AND TRANSFER WINDOW MODELS
// ============================================

model SeasonHalf {
  id            String           @id @default(uuid())
  seasonId      String           @map("season_id")
  halfType      SeasonHalfType   @map("half_type")
  startDate     DateTime?        @map("start_date")
  endDate       DateTime?        @map("end_date")
  isActive      Boolean          @default(false) @map("is_active")

  season        Season           @relation(fields: [seasonId], references: [id], onDelete: Cascade)

  // Relaciones
  plazos                Plazo[]
  transferWindows       TransferWindow[]
  transfers             Transfer[]         @relation("TransferSeasonHalf")
  transfersLoanReturn   Transfer[]         @relation("LoanReturnSeasonHalf")
  installments          TransferInstallment[]
  balances              ClubSeasonBalance[]
  playerSeasonHalfClubs PlayerSeasonHalfClub[]
  financialTransactions FinancialTransaction[]

  @@unique([seasonId, halfType])
  @@index([seasonId])
  @@index([isActive])
  @@map("season_halves")
}

model TransferWindow {
  id              String               @id @default(uuid())
  seasonHalfId    String               @map("season_half_id")
  name            String               // "Mercado Invierno T7", "Mercado Verano T7"
  startDate       DateTime             @map("start_date")
  endDate         DateTime             @map("end_date")
  status          TransferWindowStatus @default(CLOSED)

  seasonHalf      SeasonHalf           @relation(fields: [seasonHalfId], references: [id], onDelete: Cascade)
  transfers       Transfer[]

  @@index([seasonHalfId])
  @@index([status])
  @@map("transfer_windows")
}

model SeasonDeadline {
  id          String       @id @default(uuid())
  seasonId    String       @map("season_id")
  type        DeadlineType
  title       String
  description String?
  date        DateTime
  isCompleted Boolean      @default(false) @map("is_completed")
  createdAt   DateTime     @default(now()) @map("created_at")
  updatedAt   DateTime     @updatedAt @map("updated_at")

  season Season @relation(fields: [seasonId], references: [id], onDelete: Cascade)

  @@index([seasonId])
  @@map("season_deadlines")
}

// ============================================
// TRANSFER AND PAYMENT MODELS
// ============================================

model Transfer {
  id                    String          @id @default(uuid())
  type                  TransferType
  status                TransferStatus  @default(PENDING)
  playerId              String          @map("player_id")
  fromClubId            String          @map("from_club_id")
  toClubId              String          @map("to_club_id")
  initiatorClubId       String?         @map("initiator_club_id")
  transferWindowId      String?         @map("transfer_window_id")
  seasonHalfId          String          @map("season_half_id")

  // Detalles financieros
  totalAmount           Float           @default(0) @map("total_amount")
  numberOfInstallments  Int             @default(1) @map("number_of_installments")

  // Campos específicos préstamos
  loanDurationHalves    Int?            @map("loan_duration_halves")
  returnSeasonHalfId    String?         @map("return_season_half_id")
  loanFee               Float?          @map("loan_fee")
  // Porcentaje de salario que paga el club receptor (para préstamos)
  // 100 = club receptor paga todo, 50 = cada club paga mitad, 0 = dueño paga todo
  loanSalaryPercentage  Int?            @default(100) @map("loan_salary_percentage")

  notes                 String?
  createdAt             DateTime        @default(now()) @map("created_at")
  completedAt           DateTime?       @map("completed_at")

  // Relaciones
  player                Player          @relation(fields: [playerId], references: [id], onDelete: Cascade)
  fromClub              Club            @relation("TransferFromClub", fields: [fromClubId], references: [id], onDelete: Cascade)
  toClub                Club            @relation("TransferToClub", fields: [toClubId], references: [id], onDelete: Cascade)
  initiatorClub         Club?           @relation("TransferInitiator", fields: [initiatorClubId], references: [id], onDelete: SetNull)
  transferWindow        TransferWindow? @relation(fields: [transferWindowId], references: [id], onDelete: SetNull)
  seasonHalf            SeasonHalf      @relation("TransferSeasonHalf", fields: [seasonHalfId], references: [id], onDelete: Cascade)
  returnSeasonHalf      SeasonHalf?     @relation("LoanReturnSeasonHalf", fields: [returnSeasonHalfId], references: [id], onDelete: SetNull)

  installments          TransferInstallment[]
  playersAsPayment      TransferPlayerPayment[]
  transactions          FinancialTransaction[]

  @@index([playerId])
  @@index([fromClubId])
  @@index([toClubId])
  @@index([initiatorClubId])
  @@index([transferWindowId])
  @@index([seasonHalfId])
  @@index([status])
  @@index([type])
  @@map("transfers")
}

model TransferInstallment {
  id                String            @id @default(uuid())
  transferId        String            @map("transfer_id")
  installmentNumber Int               @map("installment_number")
  amount            Float
  dueSeasonHalfId   String            @map("due_season_half_id")
  status            InstallmentStatus @default(PENDING)
  paidAt            DateTime?         @map("paid_at")

  transfer          Transfer          @relation(fields: [transferId], references: [id], onDelete: Cascade)
  dueSeasonHalf     SeasonHalf        @relation(fields: [dueSeasonHalfId], references: [id], onDelete: Cascade)
  transaction       FinancialTransaction?

  @@unique([transferId, installmentNumber])
  @@index([transferId])
  @@index([dueSeasonHalfId])
  @@index([status])
  @@map("transfer_installments")
}

model TransferPlayerPayment {
  id              String    @id @default(uuid())
  transferId      String    @map("transfer_id")
  playerId        String    @map("player_id")
  valuationAmount Float     @map("valuation_amount")

  transfer        Transfer  @relation(fields: [transferId], references: [id], onDelete: Cascade)
  player          Player    @relation(fields: [playerId], references: [id], onDelete: Cascade)

  @@unique([transferId, playerId])
  @@index([transferId])
  @@index([playerId])
  @@map("transfer_player_payments")
}

// ============================================
// FINANCIAL TRACKING MODELS
// ============================================

model FinancialTransaction {
  id                  String          @id @default(uuid())
  clubId              String          @map("club_id")
  type                TransactionType
  amount              Float           // Positivo = ingreso, Negativo = gasto
  description         String
  transferId          String?         @map("transfer_id")
  installmentId       String?         @unique @map("installment_id")
  seasonHalfId        String          @map("season_half_id")
  createdAt           DateTime        @default(now()) @map("created_at")

  club                Club            @relation(fields: [clubId], references: [id], onDelete: Cascade)
  transfer            Transfer?       @relation(fields: [transferId], references: [id], onDelete: Cascade)
  installment         TransferInstallment? @relation(fields: [installmentId], references: [id], onDelete: SetNull)
  seasonHalf          SeasonHalf      @relation(fields: [seasonHalfId], references: [id], onDelete: Cascade)

  @@index([clubId])
  @@index([transferId])
  @@index([seasonHalfId])
  @@index([type])
  @@map("financial_transactions")
}

model ClubSeasonBalance {
  id              String      @id @default(uuid())
  clubId          String      @map("club_id")
  seasonHalfId    String      @map("season_half_id")
  startingBalance Float       @default(0) @map("starting_balance")
  totalIncome     Float       @default(0) @map("total_income")
  totalExpenses   Float       @default(0) @map("total_expenses")
  endingBalance   Float       @default(0) @map("ending_balance")
  totalSalaries   Float       @default(0) @map("total_salaries")

  club            Club        @relation(fields: [clubId], references: [id], onDelete: Cascade)
  seasonHalf      SeasonHalf  @relation(fields: [seasonHalfId], references: [id], onDelete: Cascade)

  @@unique([clubId, seasonHalfId])
  @@index([clubId])
  @@index([seasonHalfId])
  @@map("club_season_balances")
}

model CompetitionPrize {
  id                String          @id @default(uuid())
  competitionTypeId String          @map("competition_type_id")
  position          Int             // 1°, 2°, 3°...
  prizeAmount       Float           @map("prize_amount")
  description       String?         // "Campeón Liga A", "Subcampeón"

  competitionType   CompetitionType @relation(fields: [competitionTypeId], references: [id], onDelete: Cascade)

  @@unique([competitionTypeId, position])
  @@index([competitionTypeId])
  @@map("competition_prizes")
}

// ============================================
// PLAZO (MATCH DEADLINE PERIODS) MODELS
// ============================================

model Plazo {
  id           String     @id @default(uuid())
  seasonHalfId String     @map("season_half_id")
  title        String
  deadline     DateTime
  order        Int
  isOpen       Boolean    @default(false) @map("is_open")
  createdAt    DateTime   @default(now()) @map("created_at")
  updatedAt    DateTime   @updatedAt @map("updated_at")

  seasonHalf   SeasonHalf @relation(fields: [seasonHalfId], references: [id], onDelete: Cascade)
  scopes       PlazoScope[]
  matches      Match[]

  @@unique([seasonHalfId, order])
  @@index([seasonHalfId])
  @@map("plazos")
}

model PlazoScope {
  id             String          @id @default(uuid())
  plazoId        String          @map("plazo_id")
  competitionId  String          @map("competition_id")
  matchdayFrom   Int?            @map("matchday_from")
  matchdayTo     Int?            @map("matchday_to")
  knockoutRounds KnockoutRound[] @map("knockout_rounds")

  plazo       Plazo       @relation(fields: [plazoId], references: [id], onDelete: Cascade)
  competition Competition @relation(fields: [competitionId], references: [id], onDelete: Cascade)

  @@unique([plazoId, competitionId])
  @@index([plazoId])
  @@index([competitionId])
  @@map("plazo_scopes")
}

// Tracking de dónde jugó cada jugador por media temporada (para calcular salarios)
model PlayerSeasonHalfClub {
  id               String      @id @default(uuid())
  playerId         String      @map("player_id")
  seasonHalfId     String      @map("season_half_id")
  clubId           String      @map("club_id")
  salaryPaid       Float       @map("salary_paid")        // Salario pagado por este club esta media
  salaryPercentage Int         @default(100) @map("salary_percentage") // % del salario que pagó

  player           Player      @relation(fields: [playerId], references: [id], onDelete: Cascade)
  seasonHalf       SeasonHalf  @relation(fields: [seasonHalfId], references: [id], onDelete: Cascade)
  club             Club        @relation(fields: [clubId], references: [id], onDelete: Cascade)

  @@unique([playerId, seasonHalfId, clubId])
  @@index([playerId])
  @@index([seasonHalfId])
  @@index([clubId])
  @@map("player_season_half_clubs")
}
